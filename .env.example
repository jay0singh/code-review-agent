# Copy this file to .env and fill in the values you need. Never commit .env
# (it is gitignored). Every key is read at runtime via os.getenv; any key you
# leave unset falls back to the default noted below.

# ============================================================================
# GitHub authentication — use ONE of the two options
# ============================================================================
# The agent uses the GitHub App when all three GITHUB_APP_* values are set;
# otherwise it falls back to GITHUB_TOKEN.

# Option A — Personal Access Token (simplest). Fine-grained PAT with
# Contents (read/write), Pull requests (read/write), Issues (read/write).
# Comments post under your own account. Leave blank if you use the App below.
GITHUB_TOKEN=

# Option B — GitHub App (recommended): comments post under a bot identity and
# tokens self-rotate. ALL THREE must be set to activate App auth. See the
# "GitHub App setup" section of the README.
# Numeric App ID, e.g. 123456
GITHUB_APP_ID=
# Filesystem path to the App's .pem private key (on Render: /etc/secrets/github-app.pem)
GITHUB_APP_PRIVATE_KEY_PATH=
# Numeric installation ID, e.g. 78901234
GITHUB_APP_INSTALLATION_ID=

# ============================================================================
# Groq (AI reviews) — required
# ============================================================================
# API key from https://console.groq.com/keys
GROQ_API_KEY=

# Model used for reviews — any Groq-hosted model id.
# Default: llama-3.3-70b-versatile
REVIEW_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Review behaviour
# ============================================================================
# Max characters of patch text sent to the model per review (integer).
# Code default: 80000. On Groq's free tier (12k tokens/min) ~30000 is safer.
# Oversized diffs are automatically shrunk and retried.
MAX_DIFF_CHARS=30000

# Minimum finding severity that gets a PR review POSTED: blocker | warning | nit
# Below this the bot stays silent (no "looks good" noise); "nit" posts
# everything. Default: warning
MIN_POST_SEVERITY=warning

# Comma-separated branches whose PUSHES get commit reviews (empty = all
# branches). PR reviews are unaffected. Example: dev,main
# Default: empty (all branches)
REVIEW_BRANCHES=

# ============================================================================
# Webhook security & storage
# ============================================================================
# HMAC secret proving incoming GitHub webhooks are genuine. Generate yourself
# (e.g. openssl rand -hex 32) and paste the SAME value into the GitHub webhook's
# "Secret" field. If blank, GitHub signature verification is SKIPPED
# (not recommended outside local testing).
GITHUB_WEBHOOK_SECRET=

# SQLite file remembering already-reviewed commits/PRs AND pending Telegram
# approvals, so redelivered webhooks don't duplicate work. Survives restarts.
# Default: reviewed.db
DEDUPE_DB=reviewed.db

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# ============================================================================
# Telegram approval bot (optional)
# ============================================================================
# Leave TELEGRAM_BOT_TOKEN blank to DISABLE the whole feature — reviews then
# post straight to GitHub as before. When the bot token AND chat id are set,
# reviews are held for Approve/Reject in Telegram before they post.

# Bot token from @BotFather. Blank = feature disabled.
TELEGRAM_BOT_TOKEN=

# Chat id that receives approval prompts and is authorised to Approve/Reject
# (message @userinfobot for yours; group ids are negative). Required together
# with the bot token for gating to activate.
TELEGRAM_CHAT_ID=

# Secret token registered with Telegram's setWebhook (secret_token) and verified
# on incoming POST /telegram requests. Generate yourself (e.g. openssl rand -hex 32).
# If blank, /telegram is UNAUTHENTICATED (a warning is logged) — strongly
# recommended whenever gating is enabled.
TELEGRAM_WEBHOOK_SECRET=

# What gets held for approval: all | blockers
#   all      (default) — every PR and commit review is held for Approve/Reject.
#   blockers           — only PR reviews containing a blocker finding are held;
#                        non-blocker PR reviews and ALL commit reviews post
#                        directly. An unrecognised value fails closed (-> all).
TELEGRAM_GATE_MODE=all

# ============================================================================
# Runtime (usually not set by you)
# ============================================================================
# HTTP port. Hosts like Render inject PORT automatically; locally the
# Dockerfile/uvicorn default is 8001. Uncomment only to override.
# PORT=8001
