# Copy this file to .env and fill in your keys. Never commit .env.

# GitHub fine-grained PAT — needs Contents (r/w), Pull requests (r/w), Issues (r/w)
# (Not needed if the GitHub App settings below are filled in.)
GITHUB_TOKEN=

# GitHub App auth (optional, preferred): comments post as the bot and tokens
# rotate automatically — no more PAT expiry. Leave blank to use GITHUB_TOKEN.
# See "GitHub App setup" in the README for how to register and fill these.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=

# Groq (reviews, free tier) — create at https://console.groq.com/keys
GROQ_API_KEY=

# Webhook HMAC secret — generate yourself (e.g. openssl rand -hex 32) and
# paste the same value into the GitHub webhook's Secret field
GITHUB_WEBHOOK_SECRET=

# Model (free-tier Groq model)
REVIEW_MODEL=llama-3.3-70b-versatile

# Max characters of patch text sent per review. Groq free tier is limited to
# 12000 tokens/minute, so ~30000 is a safe value there (default is 80000).
MAX_DIFF_CHARS=30000

# Minimum finding severity that gets a PR review posted: blocker | warning | nit.
# Below this the bot stays silent. "nit" posts everything. Default: warning.
MIN_POST_SEVERITY=warning

# SQLite file remembering what was already reviewed (survives restarts)
DEDUPE_DB=reviewed.db

# Comma-separated branches whose pushes get commit reviews (empty = all).
# PR reviews are unaffected. Example: REVIEW_BRANCHES=dev,main
REVIEW_BRANCHES=
